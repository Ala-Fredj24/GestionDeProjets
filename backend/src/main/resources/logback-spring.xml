<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="APP_NAME" value="gestionprojets-backend" />
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} level=%-5level app=${APP_NAME} requestId=%X{requestId:-na} thread=%thread logger=%logger{36} - %msg%n" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="com.projetjee.backend" level="DEBUG" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.hibernate.SQL" level="WARN" />
</configuration>
